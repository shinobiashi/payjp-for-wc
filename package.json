{
    "name": "payjp-for-wc",
    "version": "0.9.5",
    "description": "PAY.JP v2 payment gateway for WooCommerce",
    "private": true,
    "license": "GPL-2.0-or-later",
    "scripts": {
        "build": "wp-scripts build",
        "start": "wp-scripts start",
        "lint:js": "wp-scripts lint-js",
        "lint:css": "wp-scripts lint-style --allow-empty-input",
        "format": "wp-scripts format",
        "env:start": "wp-env start",
        "env:stop": "wp-env stop",
        "env:clean": "wp-env clean",
        "env:destroy": "wp-env destroy",
        "env:logs": "wp-env logs",
        "env:run": "wp-env run",
        "i18n:pot": "wp i18n make-pot . languages/payjp-for-wc.pot --domain=payjp-for-wc --exclude=vendor,node_modules,tests,build",
        "i18n:json": "wp i18n make-json languages/ --no-purge && node scripts/merge-block-translations.js",
        "i18n": "npm run i18n:pot && npm run i18n:json"
    },
    "devDependencies": {
        "@playwright/test": "^1.49.0",
        "@woocommerce/dependency-extraction-webpack-plugin": "^4.0.0",
        "@wordpress/env": "^11.4.0",
        "@wordpress/scripts": "^32.0.0"
    },
    "dependencies": {
        "@wordpress/components": "*",
        "@wordpress/data": "*",
        "@wordpress/element": "*",
        "@wordpress/i18n": "*"
    }
}
